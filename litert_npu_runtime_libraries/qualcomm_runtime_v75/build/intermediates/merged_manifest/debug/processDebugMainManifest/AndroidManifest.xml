    xmlns:dist="http://schemas.android.com/apk/distribution"
    featureSplit="qualcomm_runtime_v75"
    package="com.example.efficientdet_lite"
    android:versionCode="1"
    android:versionName="1.0" >

    <uses-sdk
        android:minSdkVersion="31"
        android:targetSdkVersion="36" />

    <dist:module
        dist:instant="false"
        dist:title="@string/title_qualcomm_runtime_v75" >
        <dist:delivery>
            <dist:install-time>
                <dist:conditions>
                    <dist:device-groups>
                        <dist:device-group dist:name="Qualcomm_SM8650" />
                    </dist:device-groups>
                </dist:conditions>
            </dist:install-time>
        </dist:delivery>

        <dist:fusing dist:include="true" />
    </dist:module>

    <application
        android:debuggable="true"
        android:extractNativeLibs="false"
        android:testOnly="true" />

</manifest>